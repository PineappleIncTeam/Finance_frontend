{
	"name": "freenance-app",
	"version": "2.33.2",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build --webpack",
		"start": "next start",
		"preCommitLint": "eslint --quiet --ext .js,.jsx,.ts,.tsx,.json ./src",
		"prePushBuild": "next build --webpack",
		"typedoc:dev": "start ./docs/index.html",
		"typedoc:prod": "npx http-server ./docs -p 8081",
		"buildEcosystem": "tsc ecosystem.config.ts --skipLibCheck && node scripts/postBuildEcosystem.js",
		"build-sb": "storybook build",
		"build-typedoc": "npx typedoc --plugin typedoc-github-theme",
		"lint": "eslint --ext .js,.jsx,.ts,.tsx ./src ./scripts",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,scss,md,json} --config ./.prettierrc",
		"index": "git add ."
	},
	"dependencies": {
		"@reduxjs/toolkit": "^2.11.2",
		"@serwist/next": "^9.5.6",
		"@serwist/sw": "^9.5.6",
		"@vkid/sdk": "^2.6.5",
		"axios": "^1.13.6",
		"chart.js": "^4.5.1",
		"check-password-strength": "^3.0.0",
		"classnames": "^2.5.1",
		"date-fns": "^4.1.0",
		"moment": "^2.30.1",
		"pm2": "^6.0.14",
		"next": "16.1.6",
		"next-runtime-env": "^3.3.0",
		"pkce-challenge": "^5.0.1",
		"react": "^19.2.4",
		"react-chartjs-2": "^5.3.1",
		"react-datepicker": "^7.6.0",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.71.2",
		"react-redux": "^9.2.0",
		"redux-persist": "^6.0.0",
		"redux-saga": "^1.4.2",
		"sass": "^1.98.0",
		"serwist": "^9.5.6",
		"sharp": "^0.34.5"
	},
	"overrides": {
		"require-in-the-middle": "8.0.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@types/node": "^20.19.37",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.46.4",
		"@typescript-eslint/parser": "^8.46.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.1.6",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-hooks": "^0.4.3",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-redux": "^4.2.2",
		"eslint-plugin-solid": "^0.14.5",
		"eslint-plugin-sonarjs": "^3.0.7",
		"pre-commit": "^1.2.2",
		"pre-push": "^0.1.4",
		"prettier": "^3.8.1",
		"typedoc": "^0.28.17",
		"typescript": "5.9.3"
	},
	"license": "ISC",
	"pre-commit": [
		"preCommitLint"
	],
	"pre-push": [
		"prePushBuild"
	]
}
